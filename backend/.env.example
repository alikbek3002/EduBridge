DEBUG=False
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
LOG_TO_FILE=False
HEALTHCHECK_STRICT_DATABASE=False

# Database
# Set USE_SQLITE=True for local development without PostgreSQL.
USE_SQLITE=True
DATABASE_URL=
PGHOST=localhost
PGDATABASE=aieducation
PGUSER=postgres
PGPASSWORD=postgres
PGPORT=5432
DB_SSLMODE=prefer

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth / cookies
FEATURE_COOKIE_AUTH=True
# Local dev can use Lax. For Railway production the backend forces None/Secure for cross-site cookie auth.
COOKIE_SAMESITE=Lax
CSRF_SAMESITE=Lax

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@example.com

# OpenAI
OPENAI_API_KEY=
AI_ALLOWED_MODELS=gpt-4o-mini
AI_DAILY_TOKEN_BUDGET=50000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
